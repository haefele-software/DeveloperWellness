@page "/project/{Name}"
@using System.Globalization
@implements IDisposable
@inject DashboardState State
@inject DashboardQueryService QueryService
@inject IOptions<WellnessOptions> WellnessOptionsAccessor

<PageTitle>Pulse — @Name</PageTitle>

<p class="project-detail-back"><a href="/">← Back</a></p>

@if (_lastResult is null)
{
    <div class="project-detail-skeleton" aria-busy="true">
        <p class="visually-hidden">Loading project detail</p>
        <div class="skeleton-block"></div>
        <div class="skeleton-block"></div>
        <div class="skeleton-block"></div>
    </div>
}
else if (_lastResult.Snapshot is null)
{
    <div class="inline-error" role="alert">
        <p>@_lastResult.ErrorMessage</p>
        <button type="button" class="retry-button" @onclick="OnRetryClicked">Try again</button>
    </div>
}
else if (_lastResult.Snapshot.Dataset.Projects.Count == 0)
{
    <div class="project-not-found">
        <p>@Name is not in the covered set of projects for this organisation.</p>
        <a href="/">← Back</a>
    </div>
}
else
{
    var snapshot = _lastResult.Snapshot;
    var activeContributors = snapshot.Summaries.Where(s => s.HasActivity).ToList();
    var orderedContributors = activeContributors
        .OrderBy(s => s.Flags.Count == 0)
        .ThenBy(s => s.Developer.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ToList();
    var flaggedCount = activeContributors.Count(s => s.Flags.Count > 0);

    <div class="project-detail-page">
        @if (_lastResult.Kind != DashboardErrorKind.None)
        {
            <p class="stale-notice" role="status">
                Showing data loaded @snapshot.LoadedAt.ToLocalTime().ToString("HH:mm", CultureInfo.InvariantCulture) — the latest refresh didn't succeed: @_lastResult.ErrorMessage
            </p>
        }

        <header class="project-detail-header">
            <h1>@Name</h1>
            <p class="project-detail-subhead">Project scope · last @State.PeriodDays days · @activeContributors.Count contributor@(activeContributors.Count == 1 ? "" : "s")</p>
        </header>

        <div class="stat-tiles">
            <div class="stat-tile">
                <span class="stat-tile__label">Commits</span>
                <span class="stat-tile__value">@snapshot.Summaries.Sum(s => s.CommitCount)</span>
                <span class="stat-tile__subtext">this period</span>
            </div>
            <div class="stat-tile">
                <span class="stat-tile__label">PRs opened</span>
                <span class="stat-tile__value">@snapshot.Summaries.Sum(s => s.PrsOpenedCount)</span>
                <span class="stat-tile__subtext">this period</span>
            </div>
            <div class="stat-tile">
                <span class="stat-tile__label">Reviews</span>
                <span class="stat-tile__value">@snapshot.Summaries.Sum(s => s.ReviewCount)</span>
                <span class="stat-tile__subtext">submitted reviews</span>
            </div>
            <div class="stat-tile">
                <span class="stat-tile__label">Comments</span>
                <span class="stat-tile__value">@snapshot.Summaries.Sum(s => s.CommentCount)</span>
                <span class="stat-tile__subtext">PRs and reviews</span>
            </div>
        </div>

        <div class="project-detail-columns">
            <section class="project-detail-contributors" aria-labelledby="contributors-heading">
                <div class="project-detail-contributors__title-row">
                    <h2 id="contributors-heading">Contributors</h2>
                    <span class="project-detail-contributors__note">@ContribNote(flaggedCount, activeContributors.Count)</span>
                </div>

                @if (orderedContributors.Count == 0)
                {
                    <p class="empty-period-notice">No contributor activity recorded for this project in this period.</p>
                }
                else
                {
                    <ul class="contributor-list">
                        @foreach (var summary in orderedContributors)
                        {
                            <li class="contributor-list__item">
                                <div class="contributor-list__identity">
                                    <div class="contributor-list__avatar" style="background-color:@AvatarColor(summary.Developer.Login)" aria-hidden="true">@Initials(summary.Developer.DisplayName)</div>
                                    <a class="contributor-list__name" href="@DeveloperDetailUrl(summary.Developer.Login)">@summary.Developer.DisplayName</a>
                                </div>
                                <span class="contributor-list__activity">@BuildActivityLine(summary)</span>
                                <div class="flag-chip-row">
                                    @foreach (var flag in summary.Flags)
                                    {
                                        <FlagChip Flag="flag" />
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }

                <p class="project-detail-caption">Spread-thin isn't assessed at project scope — it only makes sense across the whole organisation.</p>
            </section>

            <AiSummaryPanel Subject="AiSubject.Project(Name)" SubjectDisplayName="@Name" />
        </div>
    </div>
}

@code {
    private readonly CancellationTokenSource _cts = new();

    private DashboardResult? _lastResult;
    private (string Name, int PeriodDays, int DataVersion)? _loadedKey;
    private bool _initialLoadStarted;

    /// <summary>The project name from the route (e.g. <c>/project/pulse-api-demo</c>).</summary>
    [Parameter]
    public string Name { get; set; } = string.Empty;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        State.Changed += OnStateChanged;
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        // This page always queries its own project scope (ScopeKey.Project(Name)) regardless of the
        // shell's currently selected scope, so the load key tracks (Name, PeriodDays) rather than
        // State.Scope: navigating between two projects, or the route Name changing, must refetch; a shell
        // scope change alone (e.g. back to Organisation while this page stays open) must not. DataVersion
        // is included so a background rate-limit retry succeeding still triggers a refetch here too.
        var currentKey = (Name, State.PeriodDays, State.DataVersion);

        if (_loadedKey is null || !_loadedKey.Value.Equals(currentKey))
        {
            // Startup-load fix: see DeveloperDetail.razor's OnParametersSetAsync for the full rationale —
            // the gate only ever applies to this instance's very first load; every later key change (once
            // _initialLoadStarted is true) loads immediately since we are then definitely past prerendering.
            if (_initialLoadStarted || EagerLoadGate.ShouldLoadEagerly(QueryService, ScopeKey.Project(Name), State.PeriodDays, WellnessOptionsAccessor.Value.DemoMode))
            {
                _initialLoadStarted = true;
                await LoadAsync();
            }
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            await LoadAsync();
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        _cts.Cancel();
        _cts.Dispose();
    }

    private void OnStateChanged()
    {
        var currentKey = (Name, State.PeriodDays, State.DataVersion);

        if (_loadedKey is null || !_loadedKey.Value.Equals(currentKey))
        {
            _ = InvokeAsync(LoadAsync);
        }
        else
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAsync()
    {
        var name = Name;
        var periodDays = State.PeriodDays;
        _loadedKey = (name, periodDays, State.DataVersion);
        _lastResult = null;
        State.SetLoading(true);

        DashboardResult result;
        try
        {
            result = await QueryService.GetAsync(ScopeKey.Project(name), periodDays, _cts.Token);
        }
        finally
        {
            State.SetLoading(false);
        }

        _lastResult = result;
        State.Apply(result);
        StateHasChanged();
    }

    private async Task OnRetryClicked()
    {
        var name = Name;
        var periodDays = State.PeriodDays;
        _loadedKey = (name, periodDays, State.DataVersion);
        _lastResult = null;
        State.SetLoading(true);

        DashboardResult result;
        try
        {
            result = await QueryService.RefreshAsync(ScopeKey.Project(name), periodDays, _cts.Token);
        }
        finally
        {
            State.SetLoading(false);
        }

        _lastResult = result;
        State.Apply(result);
        StateHasChanged();
    }

    private static string DeveloperDetailUrl(DeveloperLogin login) => $"/developer/{Uri.EscapeDataString(login.Value)}";

    private static string BuildActivityLine(ActivitySummary summary) =>
        $"{summary.CommitCount} commit{(summary.CommitCount == 1 ? "" : "s")} · " +
        $"{summary.ReviewCount} review{(summary.ReviewCount == 1 ? "" : "s")} · " +
        $"{summary.CommentCount} comment{(summary.CommentCount == 1 ? "" : "s")} · " +
        $"{summary.PrsOpenedCount} PR{(summary.PrsOpenedCount == 1 ? "" : "s")} opened";

    /// <summary>"{n} of {m} carry a flag in this scope", or "no flags in this scope" when nobody is flagged (ui-design.md 4.5).</summary>
    private static string ContribNote(int flaggedCount, int totalCount) =>
        flaggedCount > 0 ? $"{flaggedCount} of {totalCount} carry a flag in this scope" : "no flags in this scope";

    /// <summary>Up to two initials from a display name (first plus last word), for the contributor avatar circle. Matches CheckIns.razor's roster avatars.</summary>
    private static string Initials(string displayName)
    {
        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
        {
            return "?";
        }

        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    /// <summary>A deterministic HSL colour derived from the login, so the same person always gets the same avatar colour. Matches CheckIns.razor's roster avatars.</summary>
    private static string AvatarColor(DeveloperLogin login)
    {
        var hue = ((StableHash(login.Value) % 360) + 360) % 360;
        return $"hsl({hue.ToString(CultureInfo.InvariantCulture)}, 55%, 45%)";
    }

    /// <summary>
    /// A simple, process-independent string hash (unlike <see cref="string.GetHashCode()"/>, which is
    /// randomised per process), so the avatar hue is stable across app restarts and test runs.
    /// </summary>
    private static int StableHash(string value)
    {
        unchecked
        {
            var hash = 23;
            foreach (var c in value)
            {
                hash = hash * 31 + c;
            }

            return hash;
        }
    }
}
